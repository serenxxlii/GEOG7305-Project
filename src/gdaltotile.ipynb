    "from osgeo import gdal\n",
    "import os\n",
    "\n",
    "input_tif = \"./data/rgbMap.tif\"\n",
    "byte_tif = \"equity_8bit.tif\"\n",
    "output_folder = \"equity_tiles\"\n",
    "\n",
    "os.system(f\"gdal2tiles.py -p mercator -z 11-14 {input_tif} {output_folder}\")\n",
    "\n",
    "\n",
    "print(\"✅ Tiles 生成完成！\")"
   ]
